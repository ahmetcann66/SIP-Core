<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SipCore.Mobile.Views.RoadMapPage"
             Shell.NavBarIsVisible="False"
             Title="AI Sınav Haritası"
             BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Padding="20,32,20,20" Spacing="16">
            <VerticalStackLayout Spacing="6">
                <Label Text="AI Sınav Haritası" FontSize="28" FontAttributes="Bold" TextColor="#0F172A" />
                <Label Text="Konu yazarak veya hazır bir hedef seçerek yol haritası oluştur" FontSize="14" TextColor="#64748B" />
            </VerticalStackLayout>

            <Frame Padding="16" CornerRadius="18" BackgroundColor="#FFFFFF" BorderColor="#E2E8F0" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Entry x:Name="TopicEntry" Placeholder="Örnek: TYT Matematik, İngilizce, KPSS Genel Kültür" TextColor="#0F172A" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Harita Oluştur" BackgroundColor="#0EA5E9" TextColor="White" CornerRadius="12" Clicked="OnGenerateClicked" />
                        <Button Grid.Column="1" Text="Örnek Doldur" BackgroundColor="#14B8A6" TextColor="White" CornerRadius="12" Clicked="OnSampleClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16" CornerRadius="18" BackgroundColor="#EEF2FF" BorderColor="#C7D2FE" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Oluşturulan Yol Haritası" FontSize="13" FontAttributes="Bold" TextColor="#3730A3" />
                    <CollectionView x:Name="RoadMapCollection" HeightRequest="360">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="14" CornerRadius="14" BackgroundColor="White" BorderColor="#E0E7FF" HasShadow="True">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="#0F172A" />
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#475569" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Button Text="← Dashboard'a Dön"
                    BackgroundColor="#475569"
                    TextColor="White"
                    CornerRadius="12"
                    Clicked="OnBackClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>