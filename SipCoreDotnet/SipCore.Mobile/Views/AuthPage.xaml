<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SipCore.Mobile.Views.AuthPage"
             Title="Auth"
             BackgroundColor="#2C3E50">
    
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20" VerticalOptions="CenterAndExpand">
            
            <!-- Logo -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,20">
                <Label Text="🔐" FontSize="48" HorizontalTextAlignment="Center" />
                <Label Text="S.I.P. Core" FontSize="28" FontAttributes="Bold" TextColor="#ECF0F1" HorizontalTextAlignment="Center" />
                <Label Text="Giriş / Kayıt" FontSize="14" TextColor="#BDC3C7" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Email Field -->
            <VerticalStackLayout Spacing="8">
                <Label Text="📧 E-posta" FontSize="13" FontAttributes="Bold" TextColor="#ECF0F1" />
                <Entry Placeholder="ornek@email.com" 
                       Text="{Binding Email}" 
                       Keyboard="Email"
                       BackgroundColor="#FFFFFF"
                       TextColor="#2C3E50"
                       PlaceholderColor="#BDC3C7"
                       FontSize="14" />
            </VerticalStackLayout>

            <!-- Password Field -->
            <VerticalStackLayout Spacing="8">
                <Label Text="🔑 Şifre" FontSize="13" FontAttributes="Bold" TextColor="#ECF0F1" />
                <Entry Placeholder="••••••••" 
                       IsPassword="True" 
                       Text="{Binding Password}"
                       BackgroundColor="#FFFFFF"
                       TextColor="#2C3E50"
                       PlaceholderColor="#BDC3C7"
                       FontSize="14" />
            </VerticalStackLayout>

            <!-- Remember Me -->
            <CheckBox IsChecked="True" HorizontalOptions="Start" />

            <!-- Status Message -->
            <Label Text="{Binding StatusMessage}" 
                   TextColor="#E74C3C" 
                   HorizontalTextAlignment="Center"
                   FontSize="12" />

            <!-- Action Buttons -->
            <VerticalStackLayout Spacing="12" Margin="0,12,0,0">
                <Button Text="✅ Giriş Yap" 
                        Command="{Binding LoginCommand}"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="15"
                        Padding="16,12"
                        HeightRequest="48" />
                
                <Button Text="✏️ Kayıt Ol" 
                        Command="{Binding RegisterCommand}"
                        BackgroundColor="#27AE60"
                        TextColor="White"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontSize="15"
                        Padding="16,12"
                        HeightRequest="48" />
            </VerticalStackLayout>

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="#34495E" Margin="0,12" />

            <!-- Back Button -->
            <Button Text="← Geri" 
                    Command="{Binding NavigateBackCommand}"
                    BackgroundColor="#95A5A6"
                    TextColor="White"
                    CornerRadius="8"
                    FontSize="13"
                    Padding="12,8" />

            <!-- Footer -->
            <Label Text="Tüm bilgileriniz güvenle saklanır" 
                   FontSize="11" 
                   TextColor="#7F8C8D"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
