<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SipCore.Mobile.Views.HistoryPage"
             Title="Geçmiş"
             BackgroundColor="#F5F7FA">
    
    <VerticalStackLayout Padding="20" Spacing="16">
        
        <!-- Header -->
        <VerticalStackLayout Spacing="8">
            <Label Text="📜 Çalışma Geçmişi" FontSize="28" FontAttributes="Bold" TextColor="#2C3E50" />
            <Label Text="Son aktiviteleriniz" FontSize="14" TextColor="#7F8C8D" />
        </VerticalStackLayout>

        <!-- History Timeline -->
        <ScrollView>
            <CollectionView ItemsSource="{Binding HistoryItems}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📭" FontSize="40" HorizontalTextAlignment="Center" />
                        <Label Text="Henüz geçmiş kaydı yok" TextColor="#95A5A6" HorizontalTextAlignment="Center" />
                        <Label Text="Başlamak için Dashboard'a dönün" FontSize="12" TextColor="#BDC3C7" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="16" Margin="0,8" CornerRadius="12" BorderColor="#E8F4F8" BackgroundColor="#FFFFFF" HasShadow="True">
                            <HorizontalStackLayout Spacing="12">
                                <!-- Timeline Dot -->
                                <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                                    <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#3498DB" />
                                </VerticalStackLayout>
                                
                                <!-- Content -->
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand" Spacing="4">
                                    <Label Text="{Binding}" FontSize="14" FontAttributes="Bold" TextColor="#2C3E50" />
                                    <Label Text="Bugün, 14:30" FontSize="11" TextColor="#95A5A6" />
                                </VerticalStackLayout>
                                
                                <!-- Status Icon -->
                                <Label Text="✅" FontSize="18" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>
