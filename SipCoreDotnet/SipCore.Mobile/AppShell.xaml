<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SipCore.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SipCore.Mobile"
    xmlns:view="clr-namespace:SipCore.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="SipCore.Mobile">

    <ShellContent
        Title="Landing"
        ContentTemplate="{DataTemplate view:LandingPage}"
        Route="LandingPage" />

    <!-- Main Dashboard - accessible after login -->
    <ShellContent
        Title="Dashboard"
        ContentTemplate="{DataTemplate view:DashboardPage}"
        Route="DashboardPage" />

    <!-- English Hub - Full Learning Module -->
    <ShellContent
        Title="English Hub"
        ContentTemplate="{DataTemplate view:EnglishHubPage}"
        Route="EnglishHubPage" />

    <!-- SIP Core Panel -->
    <ShellContent
        Title="SIP Core"
        ContentTemplate="{DataTemplate view:SipCorePage}"
        Route="SipCorePage" />

    <!-- Level Selection -->
    <ShellContent
        Title="Seviye Seçimi"
        ContentTemplate="{DataTemplate view:LevelSelectPage}"
        Route="LevelSelectPage" />

</Shell>
